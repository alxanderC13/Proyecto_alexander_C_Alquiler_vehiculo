no changes added to commit (use "git add" and/or "git commit -a")
# =============================================================================
# DJANGO .gitignore
# =============================================================================

# ── Entorno virtual ──────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Variables de entorno ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# ── Django ───────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Archivos de migraciones generados (opcional — quita el comentario si no quieres versionar migraciones)
# */migrations/*.py
# !*/migrations/__init__.py

# Archivos estáticos recolectados
/staticfiles/
/static_root/

# Archivos de medios subidos por usuarios
/media/

# ── Caché ────────────────────────────────────────────────────────────────────
.cache/
*.cache

# ── Cobertura de tests ───────────────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
nosetests.xml

# ── Jupyter Notebooks ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs y editores ──────────────────────────────────────────────────────────
# VS Code
.vscode/
# PyCharm / IntelliJ
.idea/
*.iml
# Sublime Text
*.sublime-project
*.sublime-workspace
# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ── Sistema operativo ────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
*~

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
.dockerignore

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Documentación generada ───────────────────────────────────────────────────
docs/_build/
site/

# ── Archivos de secretos y claves ────────────────────────────────────────────
*.pem
*.key
*.p12
secrets.json